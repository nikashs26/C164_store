<div class="page-header">
  <h1><%= current_user.admin? ? "All Orders" : "My Orders" %></h1>
  <p><%= @orders.size %> orders</p>
</div>

<% if @orders.any? %>
  <div class="card-table-wrap">
    <table class="data-table">
      <thead>
        <tr>
          <th>Order</th>
          <% if current_user.admin? %><th>Customer</th><% end %>
          <th>Date</th>
          <th>Total</th>
          <th>Status</th>
          <th></th>
        </tr>
      </thead>
      <tbody>
        <% @orders.each do |order| %>
          <tr>
            <td>#<%= order.id %></td>
            <% if current_user.admin? %><td><%= order.user.name %></td><% end %>
            <td><%= order.created_at.strftime("%b %d, %Y") %></td>
            <td><%= format_price(order.total) %></td>
            <td><span class="badge badge-in-stock"><%= order.status.titleize %></span></td>
            <td><%= link_to "View", order, class: "btn btn-secondary btn-sm" %></td>
          </tr>
        <% end %>
      </tbody>
    </table>
  </div>
<% else %>
  <div class="empty-state">
    <p>No orders yet.</p>
    <%= link_to "Start Shopping", products_path, class: "btn btn-primary" %>
  </div>
<% end %>
