<div class="page-header">
  <h1>Order #<%= @order.id %></h1>
  <p><%= @order.created_at.strftime("%B %d, %Y at %I:%M %p") %></p>
</div>

<div class="profile-card" style="max-width: 100%; margin-bottom: 1.5rem;">
  <p><strong>Status</strong> <%= @order.status.titleize %></p>
  <% if current_user.admin? %>
    <p><strong>Customer</strong> <%= @order.user.name %> (<%= @order.user.email %>)</p>
  <% end %>
  <p><strong>Total</strong> <%= format_price(@order.total) %></p>
</div>

<div class="card-table-wrap">
  <table class="data-table">
    <thead>
      <tr>
        <th>Product</th>
        <th>Unit Price</th>
        <th>Qty</th>
        <th>Subtotal</th>
      </tr>
    </thead>
    <tbody>
      <% @order.order_items.each do |item| %>
        <tr>
          <td><%= link_to item.product.name, item.product %></td>
          <td><%= format_price(item.unit_price) %></td>
          <td><%= item.quantity %></td>
          <td><%= format_price(item.unit_price * item.quantity) %></td>
        </tr>
      <% end %>
    </tbody>
  </table>
</div>

<%= link_to "← Back to orders", orders_path, class: "back-link" %>
