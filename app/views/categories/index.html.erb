<div class="page-header">
  <h1>Categories</h1>
  <p>Manage product categories</p>
</div>

<div class="toolbar">
  <%= link_to "New Category", new_category_path, class: "btn btn-primary" %>
</div>

<div class="card-table-wrap">
  <table class="data-table">
    <thead>
      <tr>
        <th>Name</th>
        <th>Description</th>
        <th>Products</th>
        <th></th>
      </tr>
    </thead>
    <tbody>
      <% @categories.each do |category| %>
        <tr>
          <td><strong><%= category.name %></strong></td>
          <td class="muted"><%= category.description %></td>
          <td><%= category.products.size %></td>
          <td style="display: flex; gap: 0.5rem;">
            <%= link_to "Edit", edit_category_path(category), class: "btn btn-secondary btn-sm" %>
            <%= button_to "Delete", category_path(category), method: :delete, data: { turbo_confirm: "Delete this category?" }, class: "btn btn-danger btn-sm" %>
          </td>
        </tr>
      <% end %>
    </tbody>
  </table>
</div>
