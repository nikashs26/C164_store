<div class="page-header">
  <h1>Edit Review</h1>
  <p><%= @product.name %></p>
</div>

<%= form_with model: [@product, @review], local: true, class: "form form-wide" do |f| %>
  <% if @review.errors.any? %>
    <div class="flash flash-alert" style="margin-bottom: 1rem;">
      <ul style="margin: 0; padding-left: 1.25rem;">
        <% @review.errors.full_messages.each do |msg| %>
          <li><%= msg %></li>
        <% end %>
      </ul>
    </div>
  <% end %>

  <div class="form-group">
    <%= f.label :rating, "Rating" %>
    <%= f.select :rating, (1..5).to_a, {}, class: "form-control" %>
  </div>

  <div class="form-group">
    <%= f.label :comment, "Your review" %>
    <%= f.text_area :comment, rows: 4, class: "form-control" %>
  </div>

  <div style="display: flex; gap: 0.75rem;">
    <%= f.submit "Update Review", class: "btn btn-primary" %>
    <%= link_to "Cancel", @product, class: "btn btn-link" %>
  </div>
<% end %>
