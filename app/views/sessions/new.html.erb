<div class="page-header" style="text-align: center;">
  <h1>Welcome back</h1>
  <p>Log in to your account</p>
</div>

<div class="auth-card">
  <%= form_with url: login_path, local: true, class: "form" do %>
    <div class="form-group">
      <%= label_tag :email, "Email" %>
      <%= email_field_tag :email, params[:email], class: "form-control", placeholder: "you@example.com" %>
    </div>

    <div class="form-group">
      <%= label_tag :password, "Password" %>
      <%= password_field_tag :password, nil, class: "form-control", placeholder: "••••••••" %>
    </div>

    <%= submit_tag "Log In", class: "btn btn-primary", style: "width: 100%;" %>
  <% end %>

  <p class="form-footer">Don't have an account? <%= link_to "Sign up", signup_path %></p>
</div>
